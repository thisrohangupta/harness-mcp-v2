# This file is automatically loaded when the server starts.
# Copy this file to .env and fill in your values.

# Authentication: Provide either JWT_SECRET (for Bearer token auth) OR HARNESS_API_KEY (for API key auth), or both for dual-mode

# API Key Authentication (existing — works in stdio and HTTP modes)
HARNESS_API_KEY=pat.xxxxx.xxxxx.xxxxx
HARNESS_ACCOUNT_ID=your-account-id

# JWT Authentication (optional — enables Bearer token auth in HTTP mode)
JWT_SECRET=your-hmac-secret-minimum-32-chars
JWT_ISSUER=https://app.harness.io
JWT_AUDIENCE=harness-mcp
JWT_ALGORITHM=HS256

# Optional — defaults shown
HARNESS_BASE_URL=https://app.harness.io
HARNESS_FME_BASE_URL=https://api.split.io
HARNESS_DEFAULT_ORG_ID=default
HARNESS_DEFAULT_PROJECT_ID=
HARNESS_API_TIMEOUT_MS=30000
HARNESS_MAX_RETRIES=3
LOG_LEVEL=info

# HTTP transport only — ignored in stdio mode
PORT=3000

# Toolset filtering — comma-separated list of enabled toolsets
# If unset, all toolsets are enabled
# Available: pipelines,services,environments,infrastructure,connectors,secrets,logs,audit,delegates,repositories,registries,templates,dashboards,idp,pull-requests,feature-flags,gitops,chaos,ccm,sei,scs,sto
HARNESS_TOOLSETS=
